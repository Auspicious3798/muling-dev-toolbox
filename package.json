{
  "name": "muling-dev-toolbox",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development OPEN_DEVTOOLS=true concurrently \"yarn dev\" \"ping 127.0.0.1 -n 3 > nul && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "vue": "^3.5.30",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}